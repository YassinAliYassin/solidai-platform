{
  "version": 2,
  "builds": [
    {
      "src": "api.php",
      "use": "@vercel/php"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
