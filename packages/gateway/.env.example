# SolidAI Gateway environment configuration
# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Telegram bot token from @BotFather. DO NOT hardcode in source.
# After creating/rotating the bot, paste the value here.
TELEGRAM_BOT_TOKEN=

# Telegram user id of the platform owner/admin (used to gate /approve).
# This is the ONLY account allowed to approve new pairing codes.
OWNER_TELEGRAM_ID=1292960246

# Shared secret required by the HTTP /pairing/approve endpoint.
# Send as header: X-Admin-Secret: <value>
PAIRING_ADMIN_SECRET=

# Existing keys
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=
